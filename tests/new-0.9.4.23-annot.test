    $p endPage; set d [$p get]; $p destroy
    expr {[string first "/Subtype /FreeText" $d] >= 0}
} -result 1

test annot-2.2 {addAnnotFreeText: text in /Contents} -body {
    set p [pdf4tcl::new %AUTO% -compress 0]; $p startPage
    $p addAnnotFreeText 50 650 200 40 "UniqueFreeTxt42"
    $p endPage; set d [$p get]; $p destroy
    expr {[string first "UniqueFreeTxt42" $d] >= 0}
} -result 1

test annot-2.3 {addAnnotFreeText: /DA present} -body {
    set p [pdf4tcl::new %AUTO% -compress 0]; $p startPage
    $p addAnnotFreeText 50 650 200 40 "x"
    $p endPage; set d [$p get]; $p destroy
    expr {[string first "/DA " $d] >= 0}
} -result 1

