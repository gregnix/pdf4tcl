# --- /Annots in page ---

test annot-6.1 {annotations in /Annots page dict} -body {
    set p [pdf4tcl::new %AUTO% -compress 0]; $p startPage
    $p addAnnotNote  50 700 20 20
    $p addAnnotStamp 300 650 180 60
    $p endPage; set d [$p get]; $p destroy
    expr {[string first "/Annots \[" $d] >= 0}
} -result 1

::tcltest::cleanupTests
