# new-0.9.4.23-annot.test -- Annotation methods
source [file join [file dirname [file join [pwd] [info script]]] init.tcl]

proc mkAnnotPdf {args} {
    set p [pdf4tcl::new %AUTO% -compress 0]
    $p startPage
    $p setFont 10 Helvetica
    foreach cmd $args { {*}[linsert $cmd 1 $p] }
    $p endPage
    set d [$p get]
    $p destroy
    return $d
}

# --- addAnnotNote ---

test annot-1.1 {addAnnotNote: /Text subtype} -body {
    set p [pdf4tcl::new %AUTO% -compress 0]; $p startPage
    $p addAnnotNote 50 700 20 20
    $p endPage; set d [$p get]; $p destroy
    expr {[string first "/Subtype /Text" $d] >= 0}
} -result 1

test annot-1.2 {addAnnotNote: -content stored} -body {
    set p [pdf4tcl::new %AUTO% -compress 0]; $p startPage
    $p addAnnotNote 50 700 20 20 -content "UniqueNote99"
    $p endPage; set d [$p get]; $p destroy
    expr {[string first "UniqueNote99" $d] >= 0}
} -result 1

test annot-1.3 {addAnnotNote: -icon validation error} -body {
    set p [pdf4tcl::new %AUTO%]; $p startPage
    set err [catch {$p addAnnotNote 50 700 20 20 -icon BadIcon}]
    $p endPage; $p destroy
    set err
} -result 1

test annot-1.4 {addAnnotNote: default icon /Note} -body {
    set p [pdf4tcl::new %AUTO% -compress 0]; $p startPage
    $p addAnnotNote 50 700 20 20
    $p endPage; set d [$p get]; $p destroy
    expr {[string first "/Name /Note" $d] >= 0}
} -result 1

test annot-1.5 {addAnnotNote: -author stored} -body {
    set p [pdf4tcl::new %AUTO% -compress 0]; $p startPage
    $p addAnnotNote 50 700 20 20 -author "GregorTest"
    $p endPage; set d [$p get]; $p destroy
    expr {[string first "GregorTest" $d] >= 0}
} -result 1

