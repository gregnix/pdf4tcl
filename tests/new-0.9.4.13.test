# -- addForm -tooltip / -tabindex ----------------------------------------------

test addform-tooltip-1.1 {addForm -tooltip: creates PDF without error} {
    set f [makeFile {} test-tooltip1.pdf]
    set pdf [pdf4tcl::new %AUTO% -file $f]
    $pdf startPage
    $pdf addForm text 50 700 200 20 -id fld1 -tooltip "Enter your name"
    $pdf destroy
    file exists $f
} 1

test addform-tooltip-1.2 {addForm -tooltip: /TU in PDF} {
    set f [makeFile {} test-tooltip2.pdf]
    set pdf [pdf4tcl::new %AUTO% -compress false -file $f]
    $pdf startPage
    $pdf addForm text 50 700 200 20 -id fld1 -tooltip "MyTip"
    $pdf destroy
    pdfContains $f "/TU"
} 1

test addform-tooltip-1.3 {addForm -tooltip: tooltip text present in PDF} {
    set f [makeFile {} test-tooltip3.pdf]
    set pdf [pdf4tcl::new %AUTO% -compress false -file $f]
    $pdf startPage
    $pdf addForm text 50 700 200 20 -id fld1 -tooltip "HoverText"
    $pdf destroy
    pdfContains $f "HoverText"
} 1

test addform-tabindex-1.1 {addForm -tabindex: creates PDF without error} {
    set f [makeFile {} test-tabidx1.pdf]
    set pdf [pdf4tcl::new %AUTO% -file $f]
    $pdf startPage
    $pdf addForm text 50 700 200 20 -id fld1 -tabindex 0
    $pdf addForm text 50 650 200 20 -id fld2 -tabindex 1
    $pdf destroy
    file exists $f
} 1

test addform-tabindex-1.2 {addForm -tabindex: /TI 3 in PDF} {
    set f [makeFile {} test-tabidx2.pdf]
    set pdf [pdf4tcl::new %AUTO% -compress false -file $f]
    $pdf startPage
    $pdf addForm text 50 700 200 20 -id fld1 -tabindex 3
    $pdf destroy
    pdfContains $f "/TI 3"
} 1

test addform-tabindex-1.3 {addForm -tabindex: negative value throws} {
    set f [makeFile {} test-tabidx3.pdf]
    set pdf [pdf4tcl::new %AUTO% -file $f]
    $pdf startPage
    set err [catch {$pdf addForm text 50 700 200 20 -id fld1 -tabindex -1} msg]
    $pdf destroy
    set err
} 1

test addform-tabindex-1.4 {addForm -tabindex: non-integer throws} {
    set f [makeFile {} test-tabidx4.pdf]
    set pdf [pdf4tcl::new %AUTO% -file $f]
    $pdf startPage
    set err [catch {$pdf addForm text 50 700 200 20 -id fld1 -tabindex abc} msg]
    $pdf destroy
    set err
} 1

# -- /Tabs /R ------------------------------------------------------------------

test tabsr-1.1 {/Tabs /R present when form fields exist} {
    set f [makeFile {} test-tabsr1.pdf]
    set pdf [pdf4tcl::new %AUTO% -compress false -file $f]
    $pdf startPage
    $pdf addForm text 50 700 200 20 -id fld1
    $pdf destroy
    pdfContains $f "/Tabs /R"
} 1

test tabsr-1.2 {/Tabs /R absent without annotations} {
    set f [makeFile {} test-tabsr2.pdf]
    set pdf [pdf4tcl::new %AUTO% -compress false -file $f]
    $pdf startPage
    $pdf setFont 12 Helvetica
    $pdf text "No form fields here"
    $pdf destroy
    expr {![pdfContains $f "/Tabs /R"]}
} 1

# -- Cleanup -------------------------------------------------------------------

cleanupTests
