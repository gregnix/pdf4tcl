    set f [makeFile {} test-rg2.pdf]
    set pdf [pdf4tcl::new %AUTO% -file $f]
    $pdf startPage
    $pdf radialGradient 200 400 10 200 400 180 #ffff00 #0000ff
    $pdf destroy
    file exists $f
