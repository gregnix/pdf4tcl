# Test the examples in the examples directory                        -*-tcl-*-
#
# $Id$

set thisDir [file dirname [file join [pwd] [info script]]]
source [file join $thisDir init.tcl]

if {![file exists tcl.jpg]} {
    file link tcl.jpg ../examples/tcl.jpg
    file link gmarbles2.jpg ../examples/gmarbles2.jpg
}

# Referenz-PDFs automatisch regenerieren wenn Tcl-Version sich geaendert hat.
# Tcl 8.6 und Tcl 9 erzeugen unterschiedliche ToUnicode-CMaps.
proc regenerateExampleRefs {} {
    set exdir  [file normalize ../examples]
    set interp [info nameofexecutable]
    set curver [info patchlevel]
    set verfile [file join $exdir .tclver]

    set stored ""
    catch { set stored [string trim [read [open $verfile r]]] }
    if {$stored eq $curver} { return }

    # Version hat sich geaendert -- alle Beispiele neu erzeugen
    puts "  (regenerating example PDFs for Tcl $curver)"
    set cwd [pwd]
    cd $exdir
    foreach n {0 1 2 3 4 5 6} {
        if {[file exists test${n}.tcl]} {
            catch {exec $interp test${n}.tcl}
        }
    }
    if {[file exists test-transform.tcl]} {
        catch {exec $interp test-transform.tcl}
    }
    cd $cwd

    # Version speichern
    set fh [open $verfile w]
    puts $fh $curver
    close $fh
}

regenerateExampleRefs

# Compare two PDFs ignoring volatile timestamp fields.
proc pdfdiff {ref new} {
    set skipPat {/ModDate |/CreationDate |xmp:ModifyDate>|xmp:CreateDate>}
    proc _stripDates {file pat} {
        set fh [open $file rb]
        set lines [split [read $fh] \n]
        close $fh
        return [lsearch -all -inline -not -regexp $lines $pat]
    }
    set refF [_stripDates $ref $skipPat]
    set newF [_stripDates $new $skipPat]
    rename _stripDates {}
    if {$refF ne $newF} {
        error "PDFs differ (excluding timestamps)"
    }
    return {}
}

test examples-1.0 {example test0} -body {
    source ../examples/test0.tcl
    pdfdiff ../examples/test0.pdf test0.pdf
} -result {} -cleanup {catch {p1 destroy}}

test examples-1.1 {example test1} -body {
    source ../examples/test1.tcl
    pdfdiff ../examples/test1.pdf test1.pdf
} -result {} -cleanup {catch {p1 destroy}}

test examples-1.2 {example test2} -body {
    source ../examples/test2.tcl
    pdfdiff ../examples/test2.pdf test2.pdf
} -result {} -cleanup {catch {p1 destroy}}

test examples-1.3 {example test3} -constraints hasTk -body {
    # test3 contains an exit statement, stub it
    rename exit _exit
    proc exit args {}
    source ../examples/test3.tcl
    exec diff -a ../examples/test3.pdf test3.pdf
} -result {} -cleanup {catch {p1 destroy}; rename exit {} ; rename _exit exit}

test examples-1.4 {example test4} -constraints hasTk -body {
    # test4 contains an exit statement, stub it
    rename exit _exit
    proc exit args {}
    source ../examples/test4.tcl
    exec diff -a ../examples/test4.pdf test4.pdf
} -result {} -cleanup {catch {p1 destroy}; rename exit {} ; rename _exit exit}

test examples-1.5 {example test5} -body {
    source ../examples/test5.tcl
    pdfdiff ../examples/test5.pdf test5.pdf
} -result {} -cleanup {catch {p1 destroy}}

test examples-1.6 {example test6} -body {
    source ../examples/test6.tcl
    pdfdiff ../examples/test6.pdf test6.pdf
} -result {} -cleanup {catch {p1 destroy}}

test examples-1.7 {example test-transform} -body {
    source ../examples/test-transform.tcl
    pdfdiff ../examples/test-transform.pdf test-transform.pdf
} -result {} -cleanup {catch {$pdf destroy}}

# Cleanup
eval file delete [glob -nocomplain test*.pdf]
file delete tcl.jpg
file delete gmarbles2.jpg
::tcltest::cleanupTests
