# Test page settings                                                 -*-tcl-*-
#
# $Id$

source [file join [file dirname [file join [pwd] [info script]]] init.tcl]

test page-1.1 {page settings} -body {
    pdf4tcl::new apa
    set res {}
    lappend res [apa getDrawableArea]
    lappend res [apa cget -paper]
    apa startPage
    lappend res [apa getDrawableArea]
    apa startPage -paper a3
    lappend res [apa getDrawableArea]
    # Document setting is unaffect by page setting
    lappend res [apa cget -paper]
    apa startPage -landscape 1
    lappend res [apa getDrawableArea]
    apa startPage
    lappend res [apa getDrawableArea]
} -result {{595.0 842.0} a4 {595.0 842.0} {842.0 1190.0} a4 {842.0 595.0} {595.0 842.0}} \
        -cleanup {apa destroy}

test page-1.2 {page settings} -body {
    pdf4tcl::new apa -paper letter -landscape 1
    set res {}
    lappend res [apa getDrawableArea]
    apa startPage
    lappend res [apa getDrawableArea]
    # Change through document setting
    apa configure -paper a3
    apa startPage
    lappend res [apa getDrawableArea]
    apa configure -paper letter
    apa startPage -landscape 0
    lappend res [apa getDrawableArea]
    apa startPage
    lappend res [apa getDrawableArea]
} -result {{792.0 612.0} {792.0 612.0} {1190.0 842.0} {612.0 792.0} {792.0 612.0}} \
        -cleanup {apa destroy}

test page-1.3 {page settings, margin} -body {
    pdf4tcl::new apa -margin 10
    set res {}
    lappend res [apa getDrawableArea]
    apa startPage -margin {20 30}
    lappend res [apa getDrawableArea]
    apa configure -margin {10 20 30 40}
    apa startPage
    lappend res [apa getDrawableArea]
} -result {{575.0 822.0} {555.0 782.0} {565.0 772.0}} \
        -cleanup {apa destroy}

test page-1.4 {page settings, with unit} -body {
    pdf4tcl::new apa -unit mm -margin 10
    set res {}
    lappend res [apa getDrawableArea]
    apa startPage -margin {20 3c}
    lappend res [apa getDrawableArea]
    apa configure -margin {10 20 30p 40}
    apa startPage
    lappend res [apa getDrawableArea]
    set res2 {}
    foreach pair $res {
        foreach val $pair {
            lappend res2 [format %.3f $val]
        }
    }
    set res2
} -result {189.903 277.039 169.903 237.039 179.903 246.456} \
        -cleanup {apa destroy}

test page-1.5 {unit read only} -body {
    pdf4tcl::new apa -unit mm
    apa configure -unit i
} -cleanup {
    apa destroy
} -returnCodes 1 -result "option -unit can only be set at instance creation"

test page-2.1 {misc page handling} -body {
    pdf4tcl::new apa
    # Test multiple page commands to check robustness
    apa startPage
    apa startPage
    apa endPage
    apa endPage
    apa startPage
    apa startPage
    apa finish
    apa finish
    apa get
} -cleanup {apa destroy} -match glob \
        -result "%PDF*/Page*/Page*/Page*/Page*/Pages*/Count 4*%%EOF\n"

test page-2.2 {misc page handling, with file} -body {
    set f [makeFile {} writable.tmp]
    pdf4tcl::new apa -file $f
    # Test multiple page commands to check robustness
    apa startPage
    apa startPage
    apa endPage
    apa endPage
    # Check readonly -file
    catch {apa configure -file xxx} res
    apa startPage
    apa startPage
    apa finish
    apa finish
    apa destroy

    set ch [open $f]
    set data [read $ch]
    close $ch
    removeFile writable.tmp
    append res $data
} -match glob \
        -result "option -file can only be set at instance creation%PDF*/Page*/Page*/Page*/Page*/Pages*/Count 4*%%EOF\n"

test page-2.3 {misc page handling, rotate} -body {
    pdf4tcl::new apa -rotate 90
    apa startPage
    apa startPage -rotate 0
    apa configure -rotate 180
    apa startPage
    apa get
} -cleanup {apa destroy} -match glob \
        -result "%PDF*/Page*/Rotate 90*/Page*/Page*/Rotate 180*/Pages*/Count 3*%%EOF\n"

test page-2.4 {misc page handling, rotate} -body {
    # No rotate in document
    pdf4tcl::new apa -rotate 0
    apa startPage
    apa startPage -rotate 0
    apa startPage
    string match *Rotate* [apa get]
} -cleanup {apa destroy} -match glob \
        -result 0

test page-2.5 {misc page handling, rotate} -body {
    pdf4tcl::new apa -rotate 95
} -returnCodes 1 -match glob -result {*rotation 95 not a multiple of 90}

test page-2.6 {misc page handling, rotate} -body {
    pdf4tcl::new apa -rotate 90.0
} -returnCodes 1 -match glob -result {*bad rotation "90.0", must be integer}

test page-3.1 {file attachment annnotation} -body {
    pdf4tcl::new apa -paper {400 400} -compress 1
    apa startPage
    apa setFont 12 Times-Roman
    apa drawTextBox 10 10 200 200 "This is a text mark"
    apa embedFile "data.txt" -contents "This should be in the file." -id GG
    apa attachFile 10 10 50 50 GG "This is the description"
    apa get
} -cleanup {apa destroy} -match glob -result {*<< /Type /EmbeddedFile*This should be in the file.*<< /Type /Filespec*/F (data.txt)*<< /Type /Annot*/Contents (This is the description)*}

test page-4.1 {options errors} -body {
    pdf4tcl::new apa -mooo 1
} -returnCodes 1 -match glob -result {*unknown option "-mooo"}

test page-4.2 {options errors} -body {
    pdf4tcl::new apa -uni mm -c 1
} -returnCodes 1 -match glob -result {*unknown option "-uni"}

test page-4.3 {options errors} -body {
    pdf4tcl::new apa -unit mm
    apa configure -mooo 1
} -cleanup {
    apa destroy
} -returnCodes 1 -match glob -result {*unknown option "-mooo"}

test page-4.4 {options errors} -body {
    pdf4tcl::new apa -unit mm
    apa startXObject -mooo 1
} -cleanup {
    apa destroy
} -returnCodes 1 -match glob -result {unknown option "-mooo"}

test page-4.5 {options errors} -body {
    pdf4tcl::new apa -unit mm
    apa startXObject -landscape xxx
} -cleanup {
    apa destroy
} -returnCodes 1 -match glob -result {option -landscape must have a boolean value}

test page-4.6 {options errors} -body {
    pdf4tcl::new apa -unit mm
    apa startXObject -margin xxx
} -cleanup {
    apa destroy
} -returnCodes 1 -match glob -result {bad margin value "xxx"}

test page-4.7 {options errors} -body {
    pdf4tcl::new apa -unit mm
    apa startXObject -orient xxx
} -cleanup {
    apa destroy
} -returnCodes 1 -match glob -result {option -orient must have a boolean value}

test page-4.8 {options errors} -body {
    pdf4tcl::new apa -unit mm
    apa startXObject -noimage xxx
} -cleanup {
    apa destroy
} -returnCodes 1 -match glob -result {option -noimage must have a boolean value}

test page-4.9 {options errors} -body {
    pdf4tcl::new apa -unit mm
    apa startXObject -paper xxx
} -cleanup {
    apa destroy
} -returnCodes 1 -match glob -result {papersize "xxx" is unknown}

test page-4.10 {options errors} -body {
    pdf4tcl::new apa -unit mm
    apa startXObject -rotate xxx
} -cleanup {
    apa destroy
} -returnCodes 1 -match glob -result {bad rotation "xxx", must be numeric}

test page-4.11 {options errors} -body {
    pdf4tcl::new apa -unit xxx
} -returnCodes 1 -match glob -result {*unit "xxx" is unknown}

test page-5.1 {metadata} -body {
    mytest -all {metadata -author Peter} {
        /Author (Peter)
    }
} -result 1

test page-5.2 {metadata} -body {
    mytest -all {metadata -creator Peter} {
        /Creator (Peter)
    }
} -result 1

test page-5.3 {metadata} -body {
    mytest -all {metadata -keywords Peter} {
        /Keywords (Peter)
    }
} -result 1

test page-5.4 {metadata} -body {
    mytest -all {metadata -producer Peter} {
        /Producer (Peter)
    }
} -result 1

test page-5.5 {metadata} -body {
    mytest -all {metadata -subject Peter} {
        /Subject (Peter)
    }
} -result 1

test page-5.6 {metadata} -body {
    mytest -all {metadata -title Peter} {
        /Title (Peter)
    }
} -result 1

test page-5.7 {metadata} -body {
    mytest -all {metadata -creationdate 0} {
        /CreationDate (D:*)
    }
} -result 1

test page-5.8 {metadata} -body {
    mytest -all {metadata -creationdate 1} {
        /CreationDate (D:1970*)
    }
} -result 1

test page-6.1 {bookmarks} -body {
    mytest -all {startPage} {bookmarkAdd -title "Bookmark1"} {
        /Title (Bookmark1)
    }
} -result 1

test page-6.2 {bookmarks} -body {
    mytest -all {startPage} {bookmarkAdd -title "Bookmark1" -closed 1} {
        /Title (Bookmark1)
    }
} -result 1

test page-6.3 {bookmarks} -body {
    mytest -all {startPage} {bookmarkAdd -title ""} {   }
} -returnCodes 1 -match glob -result {option -title requires a string}

test page-6.4 {bookmarks} -body {
    mytest -all {startPage} {bookmarkAdd -level a} {   }
} -returnCodes 1 -match glob -result {bad -level "a", must be numeric}

test page-6.5 {bookmarks} -body {
    mytest -all {startPage} {bookmarkAdd -level -1} {   }
} -returnCodes 1 -match glob -result {bad -level "-1", may not be negative}

test page-6.6 {bookmarks} -body {
    mytest -all {startPage} {bookmarkAdd -closed a} {   }
} -returnCodes 1 -match glob -result {option -closed must have a boolean value}

test page-6.7 {bookmarks} -body {
    mytest -all {startPage} {bookmarkAdd -mooo a} {   }
} -returnCodes 1 -match glob -result {*unknown option "-mooo"}

::tcltest::cleanupTests

# Tests for ticket #22: metadata without setFont should not crash
# The fix replaces CleanText (font-dependent) with QuoteString for
# metadata and bookmark title strings.

test page-5.9 {metadata without setFont - no crash} -body {
    # No setFont call -- must not throw "Can't read FontsAttrs"
    set pdf [pdf4tcl::new %AUTO% -compress 0 -paper a4]
    $pdf metadata -author "Test"
    $pdf startPage
    set res [$pdf get]
    $pdf destroy
    regexp {/Author \(Test\)} $res
} -result 1

test page-5.10 {metadata without setFont - title} -body {
    set pdf [pdf4tcl::new %AUTO% -compress 0 -paper a4]
    $pdf metadata -title "My Title"
    $pdf startPage
    set res [$pdf get]
    $pdf destroy
    regexp {/Title \(My Title\)} $res
} -result 1

test page-5.11 {metadata special chars without setFont} -body {
    set pdf [pdf4tcl::new %AUTO% -compress 0 -paper a4]
    $pdf metadata -subject "Hello (World)"
    $pdf startPage
    set res [$pdf get]
    $pdf destroy
    regexp {/Subject \(Hello \\\(World\\\)\)} $res
} -result 1

test page-5.12 {metadata image-only PDF - no setFont ever} -body {
    # Reproduces the exact scenario from ticket #22
    set pdf [pdf4tcl::new %AUTO% -compress 0 -paper a4]
    $pdf metadata -creationdate 0
    $pdf metadata -author "Ticket22"
    $pdf startPage
    catch {set res [$pdf get]} err
    $pdf destroy
    # Must not error with "Can't read FontsAttrs"
    expr {$err eq "" || ![string match "*FontsAttrs*" $err]}
} -result 1

test page-6.8 {bookmarkAdd title without prior setFont} -body {
    set pdf [pdf4tcl::new %AUTO% -compress 0 -paper a4]
    $pdf startPage
    $pdf bookmarkAdd -title "Chapter 1"
    catch {set res [$pdf get]} err
    $pdf destroy
    expr {$err eq "" || ![string match "*FontsAttrs*" $err]}
} -result 1
