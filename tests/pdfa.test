# ===========================================================================
# pdfa-6.x  Metadaten-Synchronisation
# ===========================================================================

test pdfa-6.1 {metadata: title in XMP for -pdfa} -body {
    set pdf [pdf4tcl::new %AUTO% -pdfa 1b]
    $pdf metadata -title "Testdokument"
    $pdf startPage
    $pdf setFont 10 Helvetica
    $pdf text "test" -x 50 -y 700
    $pdf endPage
    set data [$pdf get]
    $pdf destroy
    expr {[string first {Testdokument} $data] >= 0}
} -result 1

test pdfa-6.2 {metadata: author in XMP for -pdfa} -body {
    set pdf [pdf4tcl::new %AUTO% -pdfa 1b]
    $pdf metadata -author "Max Mustermann"
    $pdf startPage
    $pdf setFont 10 Helvetica
    $pdf text "test" -x 50 -y 700
    $pdf endPage
    set data [$pdf get]
    $pdf destroy
    expr {[string first {Max Mustermann} $data] >= 0}
} -result 1

# ===========================================================================
# pdfa-7.x  Binary-Comment (ISO 19005-1 SS6.1.7)
# ===========================================================================

test pdfa-7.1 {binary comment: present for -pdfa 1b} -body {
    set data [make_pdfa 1b]
    # Pruefen ob Bytes >= 0x80 nach dem Header vorhanden
    set idx [string first "%PDF-" $data]
    set line2start [string first "\n" $data $idx]
    set line2end [string first "\n" $data [expr {$line2start+1}]]
    set comment [string range $data [expr {$line2start+1}] $line2end]
    # Muss mit % anfangen und mind. 4 high bytes enthalten
    expr {[string index $comment 0] eq "%" && [string length $comment] >= 5}
} -result 1

# ===========================================================================
# pdfa-8.x  Mehrere Seiten
# ===========================================================================

test pdfa-8.1 {-pdfa 1b: multiple pages work} -body {
    set pdf [pdf4tcl::new %AUTO% -pdfa 1b]
    for {set i 1} {$i <= 3} {incr i} {
        $pdf startPage
        $pdf setFont 10 Helvetica
        $pdf text "Seite $i" -x 50 -y 700
        $pdf endPage
    }
    set data [$pdf get]
    $pdf destroy
    # Alle 3 Seiten und kein /Group auf Seiten
    expr {[string first {/Count 3} $data] >= 0 && \
          [string first {/Group} $data] < 0}
} -result 1

test pdfa-8.2 {-pdfa 2b: multiple pages work} -body {
    set pdf [pdf4tcl::new %AUTO% -pdfa 2b]
    for {set i 1} {$i <= 3} {incr i} {
        $pdf startPage
        $pdf setFont 10 Helvetica
        $pdf text "Seite $i" -x 50 -y 700
        $pdf endPage
    }
    set data [$pdf get]
    $pdf destroy
    expr {[string first {/Count 3} $data] >= 0}
} -result 1


# pdfa-9.x  ICC-Profil Kompression (0.9.4.21)
# Kein echtes ICC-Profil im Test-Environment noetig:
# Wir mocken _WriteOutputIntent indem wir ein tmp-Profil erzeugen.

test pdfa-9.1 {ICC-Profil: FlateDecode bei -compress 1} -setup {
    set iccfile [makeFile [string repeat "ICCP" 512] test_icc.icc]
} -body {
    set pdf [pdf4tcl::new %AUTO% -pdfa 1b -compress 1 -pdfa-icc $iccfile]
    $pdf startPage
    $pdf setFont 10 Helvetica
    $pdf text "ICC Test" -x 50 -y 700
    $pdf endPage
    set data [$pdf get]
    $pdf destroy
    # FlateDecode muss im Stream mit /N 3 vorkommen
    regexp {/N 3[^\>]*FlateDecode|FlateDecode[^\>]*/N 3} $data
} -cleanup {
    removeFile test_icc.icc
} -result 1

test pdfa-9.2 {ICC-Profil: kein FlateDecode bei -compress 0} -setup {
    set iccfile [makeFile [string repeat "ICCP" 512] test_icc2.icc]
} -body {
    set pdf [pdf4tcl::new %AUTO% -pdfa 1b -compress 0 -pdfa-icc $iccfile]
    $pdf startPage
    $pdf setFont 10 Helvetica
    $pdf text "ICC Test" -x 50 -y 700
    $pdf endPage
    set data [$pdf get]
    $pdf destroy
    # Kein FlateDecode -- raw
    expr {![regexp {FlateDecode} $data]}
} -cleanup {
    removeFile test_icc2.icc
} -result 1

test pdfa-9.3 {ICC-Profil: komprimiertes PDF kleiner als unkomprimiertes} -setup {
    set iccfile [makeFile [string repeat "ICCP" 1024] test_icc3.icc]
} -body {
    set pdfc [pdf4tcl::new %AUTO% -pdfa 1b -compress 1 -pdfa-icc $iccfile]
    $pdfc startPage; $pdfc setFont 10 Helvetica; $pdfc text "X" -x 50 -y 700
    $pdfc endPage
    set datac [$pdfc get]; $pdfc destroy

    set pdfu [pdf4tcl::new %AUTO% -pdfa 1b -compress 0 -pdfa-icc $iccfile]
    $pdfu startPage; $pdfu setFont 10 Helvetica; $pdfu text "X" -x 50 -y 700
    $pdfu endPage
    set datau [$pdfu get]; $pdfu destroy

    expr {[string length $datac] < [string length $datau]}
} -cleanup {
    removeFile test_icc3.icc
} -result 1

# Aufraumen
cleanupTests
