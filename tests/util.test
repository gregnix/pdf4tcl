# $Id$

source [file join [file dirname [file join [pwd] [info script]]] init.tcl]

test util-1.1 {getPaperSize} -body {
    lrange [pdf4tcl::getPaperSize a4] 0 end
} -result {595.0 842.0}

test util-1.2 {getPaperSize} -body {
    lrange [pdf4tcl::getPaperSize letter] 0 end
} -result {612.0 792.0}

test util-1.3 {getPaperSize} -body {
    lrange [pdf4tcl::getPaperSize _miffo_] 0 end
} -result {}

test util-1.4 {getPaperSizeList} -body {
    lsort -dictionary [pdf4tcl::getPaperSizeList]
} -result {11x17 a0 a1 a2 a3 a4 a5 a6 ledger legal letter}

test util-1.5 {getPaperSize, case insensitive} -body {
    lrange [pdf4tcl::getPaperSize A4] 0 end
} -result {595.0 842.0}


test util-2.1 {getPoints} -body {
    set res {}
    lappend res [pdf4tcl::getPoints 1.3]
    lappend res [pdf4tcl::getPoints 15]
    lappend res [pdf4tcl::getPoints " 16 "]
    lappend res [format %.4f [pdf4tcl::getPoints 1.3i]]
    lappend res [format %.4f [pdf4tcl::getPoints 1.3mm]]
    lappend res [format %.4f [pdf4tcl::getPoints " 10 i "]]
    lappend res [format %.4f [pdf4tcl::getPoints 5mm]]
    lappend res [format %.4f [pdf4tcl::getPoints "5 cm"]]
    lappend res [format %.4f [pdf4tcl::getPoints 10c]]
    lappend res [format %.4f [pdf4tcl::getPoints 16m]]
    lappend res [pdf4tcl::getPoints 7p]
} -result {1.3 15.0 16.0 93.6000 3.6850 720.0000 14.1732 141.7323 283.4646 45.3543 7.0}

test util-2.2 {getPoints, error} -body {
    pdf4tcl::getPoints 1.3g
} -returnCodes 1 -result "unknown value 1.3g"

test util-2.3 {getPoints, error} -body {
    pdf4tcl::getPoints 1q
} -returnCodes 1 -result "unknown value 1q"

test util-2.4 {getPoints, error} -body {
    pdf4tcl::getPoints 1x1mm
} -returnCodes 1 -result "unknown value 1x1mm"

test util-3.1 {write method} -body {
    set pdf [pdf4tcl::new %AUTO%]
    $pdf startPage
    $pdf write
    $pdf destroy
} -result "" -output "%PDF-1.4*" -match glob

test util-4.1 {getCharWidth method} -body {
    set pdf [pdf4tcl::new %AUTO%]
    $pdf startPage
    $pdf setFont 20 Courier
    set res {}
    lappend res [$pdf getCharWidth ""]
    lappend res [$pdf getCharWidth " "]
    lappend res [$pdf getCharWidth "\n"]
    lappend res [$pdf getCharWidth "0"]
    lappend res [$pdf getCharWidth "00"]
    $pdf destroy
    set res
} -result {0.0 12.0 0.0 12.0 12.0}

test util-5.1 {getStringWidth method} -body {
    set pdf [pdf4tcl::new %AUTO%]
    $pdf startPage
    $pdf setFont 20 Courier
    set res {}
    lappend res [$pdf getStringWidth ""]
    lappend res [$pdf getStringWidth " "]
    lappend res [$pdf getStringWidth "w\ni"]
    lappend res [$pdf getStringWidth "MiM"]
    lappend res [$pdf getStringWidth "i i"]
    $pdf destroy
    set res
} -result {0.0 12.0 24.0 36.0 36.0}

test util-5.2 {getStringWidth method} -body {
    set pdf [pdf4tcl::new %AUTO%]
    $pdf startPage
    $pdf setFont 20 Helvetica
    set res {}
    lappend res [format %.2f [$pdf getStringWidth "MMM"]]
    lappend res [$pdf getStringWidth "MiM"]
    lappend res [$pdf getStringWidth "iii"]
    $pdf destroy
    set res
} -result {49.98 37.76 13.32}

test util-5.3 {getStringWidth method, with unit} -body {
    set pdf [pdf4tcl::new %AUTO% -unit i]
    $pdf startPage
    $pdf setFont 20p Helvetica
    set res {}
    lappend res [$pdf getStringWidth "MMM"]
    lappend res [$pdf getStringWidth "MiM"]
    lappend res [$pdf getStringWidth "iii"]
    $pdf destroy
    set res2 {}
    foreach val $res {
        lappend res2 [format %.3f $val]
    }
    set res2
} -result {0.694 0.524 0.185}

# Ticket #17: GetCharWidth fallback for unmappable WinAnsi codepoints
test util-6.1 {getStringWidth: CJK chars map to '?' width, not 0} -body {
    set pdf [pdf4tcl::new %AUTO%]
    $pdf startPage
    $pdf setFont 20 Helvetica
    set wCJK [$pdf getStringWidth "\u8f93\u5165"]
    set wQQ  [$pdf getStringWidth "??"]
    $pdf destroy
    expr {$wCJK == $wQQ}
} -result 1

test util-6.2 {getStringWidth: mixed ASCII+CJK equals ASCII+question marks} -body {
    set pdf [pdf4tcl::new %AUTO%]
    $pdf startPage
    $pdf setFont 20 Courier
    set wMix [$pdf getStringWidth "AB\u4e2d\u6587"]
    set wRef [$pdf getStringWidth "AB??"]
    $pdf destroy
    expr {$wMix == $wRef}
} -result 1

test util-6.3 {getCharWidth: unmappable codepoint > 0} -body {
    set pdf [pdf4tcl::new %AUTO%]
    $pdf startPage
    $pdf setFont 20 Helvetica
    set w [$pdf getCharWidth "\u6587"]
    $pdf destroy
    expr {$w > 0}
} -result 1

# Ticket #24: MakeToUnicodeCMap must not exceed 100 entries per beginbfchar block
test util-7.1 {CMap: 256-entry encoding produces no block > 100} -body {
    # Build a font with a 256-codepoint custom encoding and check the CMap
    set enc {}
    for {set i 0} {$i < 256} {incr i} { lappend enc [expr {0x20 + ($i % 95)}] }
    pdf4tcl::loadBaseTrueTypeFont __t24__ \
        [file join [file dirname [info script]] .. examples FreeSans.ttf]
    pdf4tcl::createFontSpecEnc __t24__ testfont256 $enc
    set cmap [pdf4tcl::MakeToUnicodeCMap testfont256 $enc]
    # No beginbfchar block may have a count > 100
    set bad 0
    foreach line [split $cmap \n] {
        if {[regexp {^(\d+) beginbfchar} $line -> n] && $n > 100} {
            set bad $n
        }
    }
    set bad
} -result 0

test util-7.2 {CMap: 256-entry encoding produces at least 3 beginbfchar blocks} -body {
    set enc {}
    for {set i 0} {$i < 256} {incr i} { lappend enc [expr {0x20 + ($i % 95)}] }
    set cmap [pdf4tcl::MakeToUnicodeCMap testfont256 $enc]
    llength [regexp -all -inline {beginbfchar} $cmap]
} -result 3

test util-7.3 {CMap: subset <= 100 uses exactly one beginbfchar block} -body {
    set enc {}
    for {set i 0} {$i < 50} {incr i} { lappend enc [expr {0x41 + $i}] }
    pdf4tcl::createFontSpecEnc __t24__ testfont50 $enc
    set cmap [pdf4tcl::MakeToUnicodeCMap testfont50 $enc]
    llength [regexp -all -inline {beginbfchar} $cmap]
} -result 1

# ---------------------------------------------------------------------------
# util-8.x  CID ToUnicode CMap -- SMP / Surrogatpaare (Ticket #25)
# ---------------------------------------------------------------------------
# Hilfsproc: erzeugt einen CID-PDF-Stream fuer einen SMP-Codepoint und
# gibt den rohen CMap-Text zurueck (uncompressed).

proc makeCIDCmap {codepoint} {
    set font /usr/share/fonts/truetype/dejavu/DejaVuSans.ttf
    if {![file exists $font]} {
        set font [file join [file dirname [info script]] .. examples FreeSans.ttf]
    }
    # Lade Font nur einmal
    if {![info exists ::pdf4tcl::BFA(__smp__,FontType)]} {
        pdf4tcl::loadBaseTrueTypeFont __smp__ $font
    }
    pdf4tcl::createFontSpecCID __smp__ __smpfont__
    set pdf [pdf4tcl::new %AUTO% -paper a4 -orient 1 -compress 0 -unit mm]
    $pdf startPage
    $pdf setFont 12 __smpfont__
    $pdf text [format "%c" $codepoint] -x 20 -y 30
    $pdf endPage
    set tmp [file join [::tcltest::temporaryDirectory] smp-[format %X $codepoint].pdf]
    $pdf write -file $tmp
    $pdf destroy
    set fd [open $tmp r]
    fconfigure $fd -encoding binary
    set raw [read $fd]
    close $fd
    file delete $tmp
    return $raw
}

test util-8.1 {CID CMap: BMP codepoint uses 4-hex-digit destination} -body {
    set raw [makeCIDCmap 0x00E4]
    # BMP: <XXXX> <YYYY> -- beide vierstellig
    set found [regexp {<[0-9A-F]{4}> <00E4>} $raw]
    set found
} -result 1

test util-8.2 {CID CMap: SMP codepoint U+1F600 ergibt UTF-16BE Surrogatpaar} -body {
    # U+1F600: u = 0x1F600 - 0x10000 = 0xF600
    # hi = 0xD800 | (0xF600 >> 10) = 0xD800 | 0x3D = 0xD83D
    # lo = 0xDC00 | (0xF600 & 0x3FF) = 0xDC00 | 0x200 = 0xDE00
    set cp 0x1F600
    set u  [expr {$cp - 0x10000}]
    set hi [expr {0xD800 | ($u >> 10)}]
    set lo [expr {0xDC00 | ($u & 0x3FF)}]
    format "%04X%04X" $hi $lo
} -result {D83DDE00}

test util-8.3 {SMP UTF-16BE surrogate pairs: algorithmic correctness} -body {
    # Testet die Surrogatpaar-Berechnung direkt ohne Font-Abhaengigkeit.
    # Bekannte Ergebnisse laut Unicode-Spec:
    #   U+10000  -> D800 DC00
    #   U+1F600  -> D83D DE00
    #   U+1F44D  -> D83D DC4D
    #   U+10FFFF -> DBFF DFFF
    set results {}
    foreach {cp expected} {
        0x10000  D800DC00
        0x1F600  D83DDE00
        0x1F44D  D83DDC4D
        0x10FFFF DBFFDFFF
    } {
        set u  [expr {$cp - 0x10000}]
        set hi [expr {0xD800 | ($u >> 10)}]
        set lo [expr {0xDC00 | ($u & 0x3FF)}]
        set got [format "%04X%04X" $hi $lo]
        lappend results [expr {$got eq $expected}]
    }
    set results
} -result {1 1 1 1}

test util-8.4 {CID CMap: codespacerange covers full 16-bit GlyphID space} -body {
    set raw [makeCIDCmap 0x0041]
    regexp {1 begincodespacerange\s*<0000> <FFFF>} $raw
} -result 1

# ---------------------------------------------------------------------------
# util-9.x  SafeQuoteString (Ticket #17 -- Tcl 9.0 Kompatibilitaet)
# ---------------------------------------------------------------------------

test util-9.1 {SafeQuoteString: reiner ASCII passiert unveraendert} -body {
    pdf4tcl::SafeQuoteString "Hello World"
} -result {(Hello World)}

test util-9.2 {SafeQuoteString: Latin-1 (U+00E4 usw.) bleibt erhalten} -body {
    pdf4tcl::SafeQuoteString "\u00e4\u00f6\u00fc\u00df"
} -result "(\u00e4\u00f6\u00fc\u00df)"

test util-9.3 {SafeQuoteString: Codepoints > U+00FF werden durch ? ersetzt} -body {
    pdf4tcl::SafeQuoteString "AB\u0100\u4e2dCD"
} -result {(AB??CD)}

test util-9.4 {SafeQuoteString: PDF-Sonderzeichen werden escaped} -body {
    pdf4tcl::SafeQuoteString "a(b)c\\d"
} -result {(a\(b\)c\\d)}

test util-9.5 {SafeQuoteString: gemischt -- SMP + Sonderzeichen} -body {
    pdf4tcl::SafeQuoteString "\U0001F600(ok)\u00e4"
} -result "(?\\(ok\\)\u00e4)"

::tcltest::cleanupTests
