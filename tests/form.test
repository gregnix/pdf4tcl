# Test form commands                                                 -*-tcl-*-
#
# $Id$

source [file join [file dirname [file join [pwd] [info script]]] init.tcl]

test form-1.1 {addForm method, errors} -body {
    mytest {addForm apa 0 0 10 10} {
    }
} -returnCodes 1 -result "unknown form type apa"

test form-1.2 {addForm method, errors} -body {
    mytest {addForm checkbutton 0 0 10 10 -init hej} {
    }
} -returnCodes 1 -result "initial value for checkbutton must be boolean"

test form-1.3 {addForm method, errors} -body {
    mytest {addForm checkbutton 0 0 10 10 -on hej} {
    }
} -returnCodes 1 -result "bad id for -on"

test form-1.4 {addForm method, errors} -body {
    mytest {addForm checkbutton 0 0 10 10 -off hej} {
    }
} -returnCodes 1 -result "bad id for -off"

test form-1.5 {addForm method, errors} -body {
    mytest {addForm text 0 0 10 10 -multiline hej} {
    }
} -returnCodes 1 -result "option -multiline must have a boolean value"

test form-1.6 {addForm method, errors} -body {
    mytest {addForm text 0 0 10 10 -id 6.7} {
    }
} -returnCodes 1 -result "option -id must be alphanumeric"

test form-2.1 {addForm method, text} -body {
    mytest -all {addForm text 0 0 10 10} {
        /Subtype /Widget * /FT /Tx /T * /DA
    }
} -result 1

test form-2.2 {addForm method, text} -body {
    mytest -all {addForm text 0 0 10 10 -init Hurga} {
        /Subtype /Widget * /FT /Tx /T * /DA * /V (Hurga)
    }
} -result 1

test form-2.3 {addForm method, text} -body {
    mytest -all {addForm text 0 0 10 10 -id MyPrecious} {
        /Subtype /Widget * /FT /Tx /T (MyPrecious) /DA
    }
} -result 1

test form-3.1 {addForm method, checkbutton} -body {
    mytest -all {addForm checkbutton 0 0 10 10} {
        /Subtype /Widget * /FT /Btn /T * /AS /Off
    }
} -result 1

test form-3.2 {addForm method, checkbutton} -body {
    mytest -all {addForm checkbutton 0 0 10 10 -init true} {
        /Subtype /Widget * /FT /Btn /T * /AS /Yes
    }
} -result 1

test form-3.3 {addForm method, checkbutton} -body {
    mytest -all {addForm checkbutton 0 0 10 10 -id TheSuperForm} {
        /Subtype /Widget * /FT /Btn /T (TheSuperForm) /AS /Off
    }
} -result 1

test form-4.1 {getForms command} -body {
    mytest -file {addForm text 0 0 10 10 -id MyPrecious} {}
    pdf4tcl::getForms testdebug.pdf
} -cleanup {file delete testdebug.pdf} -result [list MyPrecious [list type /Tx value {} flags 0]]

test form-4.2 {getForms command} -body {
    mytest -file {addForm checkbutton 0 0 10 10 -id TheSuperForm} {}
    pdf4tcl::getForms testdebug.pdf
} -cleanup {file delete testdebug.pdf} -result [list TheSuperForm [list type /Btn default /Off value /Off flags 0]]

::tcltest::cleanupTests
