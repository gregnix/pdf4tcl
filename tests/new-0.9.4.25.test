# Tests for pdf4tcl 0.9.4.25
# - write -chan option
# - ISO B/C paper sizes + 4A0/2A0

package require tcltest 2.2
namespace import ::tcltest::*

set thisDir [file dirname [file normalize [info script]]]
source [file join $thisDir init.tcl]

# ---------------------------------------------------------------------------
# write -chan tests
# ---------------------------------------------------------------------------

test write-1.1 {write -chan: output to channel} -body {
    set pdf [::pdf4tcl::new %AUTO% -paper a4 -orient true]
    $pdf startPage
    $pdf setFont 12 Helvetica
    $pdf text "Chan test" -x 50 -y 50
    $pdf endPage
    # Write to a pipe channel (via file channel)
    set tmpfile [file join [tcltest::temporaryDirectory] write_chan_test.pdf]
    set ch [open $tmpfile w]
    $pdf write -chan $ch
    close $ch
    $pdf destroy
    # Verify PDF header
    set fd [open $tmpfile rb]
    set hdr [read $fd 4]
    close $fd
    file delete $tmpfile
    set hdr
} -result "%PDF"

test write-1.2 {write -chan: content identical to -file} -body {
    set pdf [::pdf4tcl::new %AUTO% -paper a4 -orient true]
    $pdf startPage
    $pdf setFont 10 Helvetica
    $pdf text "Comparison test" -x 50 -y 100
    $pdf endPage

    set f1 [file join [tcltest::temporaryDirectory] w25_file.pdf]
    set f2 [file join [tcltest::temporaryDirectory] w25_chan.pdf]

    $pdf write -file $f1

    set ch [open $f2 w]
    $pdf write -chan $ch
    close $ch
    $pdf destroy

    set sz1 [file size $f1]
    set sz2 [file size $f2]
    file delete $f1 $f2
    expr {$sz1 == $sz2}
} -result 1

test write-1.3 {write -chan: unknown option still errors} -body {
    set pdf [::pdf4tcl::new %AUTO% -paper a4 -orient true]
    $pdf startPage
    $pdf endPage
    set rc [catch {$pdf write -badopt foo} err]
    $pdf destroy
    set rc
} -result 1

# ---------------------------------------------------------------------------
# ISO paper size tests
# ---------------------------------------------------------------------------

test paper-1.1 {paper sizes: B-series exist} -body {
    set ok 1
    foreach p {b0 b1 b2 b3 b4 b5 b6 b7 b8 b9 b10} {
        if {[pdf4tcl::getPaperSize $p] eq {}} { set ok 0; break }
    }
    set ok
} -result 1

test paper-1.2 {paper sizes: C-series exist} -body {
    set ok 1
    foreach p {c0 c1 c2 c3 c4 c5 c6 c7 c8 c9 c10} {
        if {[pdf4tcl::getPaperSize $p] eq {}} { set ok 0; break }
    }
    set ok
} -result 1

test paper-1.3 {paper sizes: 4a0 and 2a0 exist} -body {
    set r1 [pdf4tcl::getPaperSize 4a0]
    set r2 [pdf4tcl::getPaperSize 2a0]
    expr {$r1 ne {} && $r2 ne {}}
} -result 1

test paper-1.4 {paper sizes: b5 correct dimensions} -body {
    lassign [pdf4tcl::getPaperSize b5] w h
    # b5 = 499 x 709 pt
    expr {$w == 499.0 && $h == 709.0}
} -result 1

test paper-1.5 {paper sizes: c4 correct dimensions} -body {
    lassign [pdf4tcl::getPaperSize c4] w h
    # c4 = 649 x 918 pt
    expr {$w == 649.0 && $h == 918.0}
} -result 1

test paper-1.6 {paper sizes: a4 value unchanged (backward compat)} -body {
    lassign [pdf4tcl::getPaperSize a4] w h
    expr {$w == 595.0 && $h == 842.0}
} -result 1

test paper-1.7 {paper sizes: create PDF with b5} -body {
    set pdf [::pdf4tcl::new %AUTO% -paper b5 -orient true]
    $pdf startPage
    $pdf setFont 10 Helvetica
    $pdf text "B5 paper" -x 50 -y 50
    $pdf endPage
    set data [$pdf get]
    $pdf destroy
    string match "*%PDF*" $data
} -result 1

test paper-1.8 {paper sizes: version is 0.9.4.25} -body {
    package require pdf4tcl
    package versions pdf4tcl
} -match glob -result *0.9.4.25*

cleanupTests
