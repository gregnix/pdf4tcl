# tcl-sha 2.1.1 -- Patch fuer Tcl 9 Kompatibilitaet
# Anwendung: cd sha-src-2.1.1 && patch -p1 < tclsha-tcl9.patch
# Getestet: Tcl 8.6.17, Tcl 9.0.3, Linux x86_64
# Erstellt: 2026-03-18 (gregnix/pdf4tcl)
#
# Aenderungen:
#   tclsha.c:    Tcl_Size-Shim (Tcl 9 compat), int->Tcl_Size fuer OUT-Parameter
#   pkgIndex.tcl: string totitle fuer Tcl 9 Init-Funktionsname

--- a/tclsha.c
+++ b/tclsha.c
@@ -15,6 +15,17 @@
 #include <string.h>
 #include <tcl.h>
 
+/* Tcl 9 Tcl_Size compatibility shim for Tcl 8.6 builds */
+#ifndef TCL_SIZE_MAX
+#  include <limits.h>
+#  define TCL_SIZE_MAX INT_MAX
+#  ifndef Tcl_Size
+     typedef int Tcl_Size;
+#  endif
+#  define TCL_SIZE_MODIFIER ""
+#  define Tcl_GetSizeIntFromObj Tcl_GetIntFromObj
+#endif
+
 #include "sha.h"
 
 static const char* OutputFormats[] = {
@@ -151,7 +162,7 @@
 
 static int convert_to_binary(Tcl_Obj* tclObj, char** bufOut, int* doFree) {
     int i = 0;
-    int len;
+    Tcl_Size len;
     Tcl_UniChar* uniStr = Tcl_GetUnicodeFromObj(tclObj, &len);
     *bufOut = ckalloc(len);
     *doFree = 1;
@@ -175,10 +186,10 @@
   char              *key;         /* key data specified by -key (hmac)  */
   int               keyDynAlloc = 0;
   char              *fn;
-  int               len;
+  Tcl_Size          len;
   char              *sz;
-  int               szlen;
-  int               klen;
+  Tcl_Size          szlen;
+  Tcl_Size          klen;
   int               rc;
   int               argidx;
   int               argcount;
@@ -247,7 +258,7 @@
       } else if (strcmp(buf, "-datahex") == 0) {
           ++argidx;
           if (argidx < objc) {
-              int dhexlen = 0;
+              Tcl_Size dhexlen = 0;
               char* dhex = Tcl_GetStringFromObj(objv[argidx], &dhexlen);
               msz = hexs2bin(dhex, &dbuf, &dataDynAlloc);
               flags |= SHA_HAVEDATA;
@@ -267,7 +278,7 @@
       } else if (strcmp(buf, "-keyhex") == 0) {
         ++argidx;
         if (argidx < objc) {
-          int khexlen = 0;
+          Tcl_Size khexlen = 0;
           char* khex = Tcl_GetStringFromObj(objv[argidx], &khexlen);
           klen = hexs2bin(khex, &key, &keyDynAlloc);
           havemac += 1;
--- a/pkgIndex.tcl
+++ b/pkgIndex.tcl
@@ -18,7 +18,9 @@
 
 package ifneeded sha ${shaver} \
     [list load [file join $dir ${osname}${osbits} \
-    sha[info sharedlibextension]]]
+    sha[info sharedlibextension]] \
+    [if {[package vsatisfies [package provide Tcl] 9.0-]} \
+        {string totitle sha} {subst sha}]]
 
 unset -nocomplain osbits
 unset -nocomplain osplatform
