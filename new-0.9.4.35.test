# new-0.9.4.35.test -- hardening of QuoteString and the random source  -*-tcl-*-
#
#   QuoteString        transliterates typography, replaces what cannot be
#                      represented, drops control characters (with one warning)
#   _EncRandBytes      cryptographic sources only; no silent fallback to rand()
#   getSubstCount      makes the silent '?' replacement in CleanText countable
#
# Background: PDF literal strings go into the binary output, and Tcl 9.0
# rejects codepoints above U+00FF on a binary channel. Before, such a character
# did not fail where it was introduced but much later in [finish], as
#   expected code point values below 0xff but value at byte offset N was 0x...
# hundreds of kilobytes away from its origin.

source [file join [file dirname [file join [pwd] [info script]]] init.tcl]

# getSubstCount is exact only from Tcl 9 on. Under 8.6 [encoding convertto]
# performs its own silent replacement and returns without an error, so pdf4tcl
# never learns that a character was lost -- the counter stays 0 there. This is
# a property of the Tcl release, not of pdf4tcl.
tcltest::testConstraint tcl9 [package vsatisfies [package provide Tcl] 9-]

# Encryption needs Tcllib md5 and aes. encrypt.test simply requires them and
# is skipped as a whole when they are missing; here only three tests depend on
# them, so they get a constraint of their own.
tcltest::testConstraint hasCrypto \
        [expr {![catch {package require md5}] && ![catch {package require aes}]}]

# ---------------------------------------------------------------------------
# QuoteString: escaping unchanged
# ---------------------------------------------------------------------------

test quote-1.1 {parentheses are still escaped} -body {
    ::pdf4tcl::QuoteString "Hallo (Welt)"
} -result {(Hallo \(Welt\))}

test quote-1.2 {backslash is still escaped} -body {
    ::pdf4tcl::QuoteString {Backslash \ hier}
} -result {(Backslash \\ hier)}

test quote-1.3 {the whitespace escapes are unchanged} -body {
    ::pdf4tcl::QuoteString "a\nb\tc\rd"
} -result {(a\nb\tc\rd)}

test quote-1.4 {plain ASCII passes through} -body {
    ::pdf4tcl::QuoteString "plain ascii 123"
} -result {(plain ascii 123)}

# ---------------------------------------------------------------------------
# QuoteString: transliteration of common typography
# ---------------------------------------------------------------------------

test quote-2.1 {en dash and em dash become a hyphen} -body {
    ::pdf4tcl::QuoteString "a \u2013 b \u2014 c"
} -result {(a - b - c)}

test quote-2.2 {typographic double quotes become straight ones} -body {
    ::pdf4tcl::QuoteString "\u201EHallo\u201C und \u201CHi\u201D"
} -result {("Hallo" und "Hi")}

test quote-2.3 {typographic single quotes become straight ones} -body {
    ::pdf4tcl::QuoteString "\u2018a\u2019 \u201Ab\u201B"
} -result {('a' 'b')}

test quote-2.4 {an ellipsis becomes three dots} -body {
    ::pdf4tcl::QuoteString "und \u2026"
} -result {(und ...)}

test quote-2.5 {arrows and comparisons} -body {
    ::pdf4tcl::QuoteString "\u2190 \u2192 \u2264 \u2265 \u2260"
} -result {(<- -> <= >= !=)}

test quote-2.6 {euro, trademark, numero} -body {
    ::pdf4tcl::QuoteString "\u20AC \u2122 \u2116"
} -result {(EUR \(TM\) No.)}

test quote-2.7 {a zero width space disappears} -body {
    ::pdf4tcl::QuoteString "a\u200Bb"
} -result {(ab)}

test quote-2.8 {what has no transliteration becomes a question mark} -body {
    ::pdf4tcl::QuoteString "x \u4E2D\u6587 y"
} -result {(x ?? y)}

# ---------------------------------------------------------------------------
# QuoteString: Latin-1 must not be touched
# ---------------------------------------------------------------------------

test quote-3.1 {umlauts survive} -body {
    ::pdf4tcl::QuoteString "\u00E4\u00F6\u00FC\u00DF"
} -result "(\u00E4\u00F6\u00FC\u00DF)"

test quote-3.2 {a non-breaking space is not replaced} -body {
    # U+00A0 is representable as 0xA0 and must stay, even when the same
    # string triggers the transliteration through another character.
    string equal [::pdf4tcl::QuoteString "a\u00A0b \u2014"] "(a\u00A0b -)"
} -result 1

test quote-3.3 {a middle dot is not replaced} -body {
    string equal [::pdf4tcl::QuoteString "a\u00B7b \u2014"] "(a\u00B7b -)"
} -result 1

# ---------------------------------------------------------------------------
# QuoteString: the result is always writable to a binary channel
# ---------------------------------------------------------------------------

test quote-4.1 {no codepoint above 0xFF survives} -body {
    set s [::pdf4tcl::QuoteString "\u2014 \u20AC \u4E2D \u2026 \uFFFD"]
    regexp {[^\x00-\xFF]} $s
} -result 0

test quote-4.2 {control characters are dropped} -setup {
    set ::pdf4tcl::warnings {}
} -body {
    # \x00 and \x1F have no place in a PDF string.
    ::pdf4tcl::QuoteString "a\x00b\x1Fc"
} -cleanup {
    set ::pdf4tcl::warnings {}
} -result {(abc)}

test quote-4.2b {a control character is reported in ::pdf4tcl::warnings} -setup {
    set ::pdf4tcl::warnings {}
} -body {
    ::pdf4tcl::QuoteString "a\x00b"
    list [llength $::pdf4tcl::warnings] \
         [string match "*control character*" [lindex $::pdf4tcl::warnings 0]]
} -cleanup {
    set ::pdf4tcl::warnings {}
} -result {1 1}

test quote-4.2c {the report appears only once} -setup {
    set ::pdf4tcl::warnings {}
} -body {
    ::pdf4tcl::QuoteString "a\x00b"
    ::pdf4tcl::QuoteString "c\x01d"
    ::pdf4tcl::QuoteString "e\x02f"
    llength $::pdf4tcl::warnings
} -cleanup {
    set ::pdf4tcl::warnings {}
} -result 1

test quote-4.2d {resetting the list re-arms the report} -setup {
    set ::pdf4tcl::warnings {}
} -body {
    ::pdf4tcl::QuoteString "a\x00b"
    set ::pdf4tcl::warnings {}
    ::pdf4tcl::QuoteString "c\x01d"
    llength $::pdf4tcl::warnings
} -cleanup {
    set ::pdf4tcl::warnings {}
} -result 1

test quote-4.2e {transliteration alone reports nothing} -setup {
    set ::pdf4tcl::warnings {}
} -body {
    ::pdf4tcl::QuoteString "a \u2014 b \u20AC"
    llength $::pdf4tcl::warnings
} -cleanup {
    set ::pdf4tcl::warnings {}
} -result 0

test quote-4.2f {the PDF/A warning list is not disturbed} -setup {
    set ::pdf4tcl::warnings {}
} -body {
    # ::pdf4tcl::warnings is the package's existing list of non-fatal
    # compliance notes. QuoteString appends to it; it must not preempt it.
    set pdf [::pdf4tcl::new %AUTO% -paper a4 -pdfa 1b]
    $pdf startPage
    catch {$pdf setAlpha 0.5}
    catch {$pdf destroy}
    list [llength $::pdf4tcl::warnings] \
         [string match "*setAlpha*" [lindex $::pdf4tcl::warnings 0]]
} -cleanup {
    set ::pdf4tcl::warnings {}
} -result {1 1}

test quote-4.3 {SafeQuoteString is an alias} -body {
    string equal [::pdf4tcl::SafeQuoteString "a \u2014 b"] \
                 [::pdf4tcl::QuoteString  "a \u2014 b"]
} -result 1

# ---------------------------------------------------------------------------
# The methods that write user text no longer abort
# ---------------------------------------------------------------------------

proc buildWith {script} {
    set pdf [::pdf4tcl::new %AUTO% -paper a4]
    $pdf startPage
    $pdf setFont 12 Helvetica
    uplevel 1 [list set ::qpdf $pdf]
    uplevel 1 $script
    $pdf endPage
    set code [catch {$pdf get} res]
    $pdf destroy
    return $code
}

test quote-5.1 {bookmarkAdd with an en dash} -body {
    buildWith {$::qpdf bookmarkAdd -title "Chapter 1 \u2013 Introduction"}
} -result 0

test quote-5.2 {metadata with an en dash} -body {
    buildWith {$::qpdf metadata -title "Report 2026 \u2013 Summary"}
} -result 0

test quote-5.3 {hyperlinkAdd with an em dash in the URL} -body {
    buildWith {$::qpdf hyperlinkAdd 10 10 50 12 "https://example.com/\u2014"}
} -result 0

test quote-5.4 {addAnnotNote with an em dash} -body {
    buildWith {$::qpdf addAnnotNote 20 20 30 30 -content "Text \u2014 hier"}
} -result 0

test quote-5.5 {addAnnotHighlight with an em dash} -body {
    buildWith {$::qpdf addAnnotHighlight 20 20 60 30 -content "Text \u2014"}
} -result 0

test quote-5.6 {a bookmark title arrives transliterated} -body {
    set pdf [::pdf4tcl::new %AUTO% -compress 0 -paper a4]
    $pdf startPage
    $pdf setFont 12 Helvetica
    $pdf bookmarkAdd -title "Chapter 1 \u2013 Introduction"
    $pdf endPage
    set d [$pdf get]
    $pdf destroy
    string match {*Chapter 1 - Introduction*} $d
} -result 1

# ---------------------------------------------------------------------------
# getSubstCount
# ---------------------------------------------------------------------------

test subst-1.1 {a fresh document starts at zero} -body {
    set pdf [::pdf4tcl::new %AUTO% -paper a4]
    set n [$pdf getSubstCount]
    $pdf destroy
    set n
} -result 0

test subst-1.2 {pure ASCII replaces nothing} -body {
    set pdf [::pdf4tcl::new %AUTO% -paper a4]
    $pdf startPage
    $pdf setFont 12 Helvetica
    $pdf text "Plain ASCII only" -x 72 -y 700
    set n [$pdf getSubstCount]
    $pdf destroy
    set n
} -result 0

test subst-1.3 {characters outside the font encoding are counted} \
        -constraints {tcl9} -body {
    set pdf [::pdf4tcl::new %AUTO% -paper a4]
    $pdf startPage
    $pdf setFont 12 Helvetica
    # An em dash is cp1252 0x97 and representable; the two CJK ones are not.
    $pdf text "Mit \u2014 und \u4E2D\u6587" -x 72 -y 700
    set n [$pdf getSubstCount]
    $pdf destroy
    set n
} -result 2

test subst-1.4 {the counter is per document} -constraints {tcl9} -body {
    set a [::pdf4tcl::new %AUTO% -paper a4]
    $a startPage
    $a setFont 12 Helvetica
    $a text "\u4E2D\u6587" -x 72 -y 700
    set b [::pdf4tcl::new %AUTO% -paper a4]
    set res [list [$a getSubstCount] [$b getSubstCount]]
    $a destroy
    $b destroy
    set res
} -result {2 0}

# ---------------------------------------------------------------------------
# _EncRandBytes -- the backend is chosen, never silently weakened
# ---------------------------------------------------------------------------

test rand-1.1 {a cryptographic backend is selected} -constraints {unix hasCrypto} -body {
    catch {unset ::pdf4tcl::_randBackend}
    set pdf [::pdf4tcl::new %AUTO% -paper a4 -userpassword "x"]
    $pdf startPage
    $pdf setFont 12 Helvetica
    $pdf text "Secret" -x 72 -y 700
    $pdf endPage
    catch {$pdf get}
    $pdf destroy
    expr {$::pdf4tcl::_randBackend in {urandom twapi powershell}}
} -result 1

test rand-1.2 {two documents get different keys} -constraints {unix hasCrypto} -body {
    proc _mk {} {
        set pdf [::pdf4tcl::new %AUTO% -paper a4 -userpassword "x"]
        $pdf startPage
        $pdf setFont 12 Helvetica
        $pdf text "Secret" -x 72 -y 700
        $pdf endPage
        set d [$pdf get]
        $pdf destroy
        return $d
    }
    set a [_mk]
    set b [_mk]
    rename _mk {}
    expr {$a ne $b}
} -result 1

test rand-1.3 {an encrypted document really is encrypted} -constraints {unix hasCrypto} -body {
    set pdf [::pdf4tcl::new %AUTO% -paper a4 -userpassword "x"]
    $pdf startPage
    $pdf setFont 12 Helvetica
    $pdf text "Secret" -x 72 -y 700
    $pdf endPage
    set d [$pdf get]
    $pdf destroy
    regexp {/Filter\s*/Standard} $d
} -result 1

::tcltest::cleanupTests
